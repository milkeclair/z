{
  "name": "z-ls",
  "displayName": "z-ls",
  "author": "milkeclair",
  "publisher": "milkeclair",
  "description": "Language Server for z",
  "license": "MIT",
  "version": "2.2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/milkeclair/z"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:shellscript"
  ],
  "main": "./client/dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "shellscript",
        "aliases": [
          "Shell Script",
          "shellscript"
        ],
        "extensions": [
          ".zsh"
        ]
      }
    ],
    "configuration": {
      "type": "object",
      "title": "z-ls",
      "properties": {
        "z-ls.zPath": {
          "scope": "resource",
          "type": "string",
          "default": "~/.z",
          "description": "Path to the z root directory. Defaults to ~/.z"
        },
        "z-ls.completion.showPrivateFunctions": {
          "scope": "resource",
          "type": "boolean",
          "default": false,
          "description": "Show private z functions in completion results."
        }
      }
    }
  },
  "scripts": {
    "b": "tsc -b",
    "clean": "rm -rf client/dist server/dist client/tsconfig.tsbuildinfo server/tsconfig.tsbuildinfo",
    "vscode:prepublish": "tsc -b",
    "package": "rm -f bun.lock && bun install && npm run clean && npm run vscode:prepublish && vsce package"
  },
  "dependencies": {
    "glob": "^13.0.6",
    "vscode-languageclient": "^10.0.0",
    "vscode-languageserver": "^10.0.0",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.9.2",
    "typescript": "^6.0.3",
    "@types/node": "^25.9.3",
    "@types/vscode": "^1.125.0"
  }
}
